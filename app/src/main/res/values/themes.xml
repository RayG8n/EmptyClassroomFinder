<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.EmptyClassroomFinder" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/parchment_cream</item>
        <item name="colorPrimary">@color/chalkboard_green</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="Theme.EmptyClassroomFinder" parent="Base.Theme.EmptyClassroomFinder" />

    <!-- Minimalist Button Style -->
    <style name="Widget.Classroom.Button" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/chalkboard_green</item>
        <item name="android:textColor">@color/chalk_white</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="shapeAppearance">@null</item>
    </style>
</resources>